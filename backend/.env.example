# -------------------------------------------------------
# InfraPilot — Backend Environment Variables
# -------------------------------------------------------
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# -------------------------------------------------------

# GitHub OAuth App credentials
# Create one at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# PostgreSQL connection string
DATABASE_URL=postgresql://infrapilot:infrapilot@localhost:5432/infrapilot

# Caddy reverse proxy admin API
CADDY_API_URL=http://localhost:2019

# Base domain for generated deployment URLs
# Use "localhost" for local dev, your domain (e.g. infrapilot.dev) in production
BASE_DOMAIN=localhost

# Port range allocated for managed deployments
# Each deployment gets a unique port in this range
PORT_RANGE_START=9000
PORT_RANGE_END=9500
